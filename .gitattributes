# Auto-detect text files and normalize line endings in the repo to LF.
# Working-tree files get native endings on checkout.
* text=auto eol=lf

# Source files — force LF everywhere
*.java       text eol=lf diff=java
*.xml        text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.properties text eol=lf
*.md         text eol=lf
*.json       text eol=lf
*.sh         text eol=lf
*.gitignore  text eol=lf
*.gitattributes text eol=lf

# Windows-only scripts must stay CRLF or cmd.exe gets confused
*.bat        text eol=crlf
*.cmd        text eol=crlf

# Binary — never touch line endings
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.ico        binary
*.jar        binary
*.war        binary
*.ear        binary
*.zip        binary
*.gz         binary
*.tar        binary
*.pdf        binary
*.class      binary
